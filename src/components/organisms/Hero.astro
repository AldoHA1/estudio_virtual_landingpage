---

---

<section
  id="hero"
  class="relative pt-40 pb-24 px-8 overflow-hidden min-h-screen flex items-center"
>
  <!-- Animated background blobs -->
  <div class="absolute inset-0 pointer-events-none overflow-hidden">
    <div class="absolute -top-40 -left-40 w-[500px] h-[500px] bg-primary/10 dark:bg-blue-500/10 rounded-full blur-[120px] animate-pulse-glow"></div>
    <div class="absolute top-1/3 right-0 w-[400px] h-[400px] bg-pink/10 dark:bg-pink-500/10 rounded-full blur-[120px] animate-pulse-glow" style="animation-delay: 1.5s;"></div>
    <div class="absolute bottom-0 left-1/3 w-[350px] h-[350px] bg-cyan/10 dark:bg-cyan-500/8 rounded-full blur-[120px] animate-pulse-glow" style="animation-delay: 3s;"></div>
  </div>

  <div
    class="max-w-7xl mx-auto w-full grid grid-cols-1 md:grid-cols-12 gap-12 items-center"
  >
    <div class="md:col-span-8 z-10">
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-primary/5 dark:bg-blue-500/10 border border-primary/10 dark:border-blue-500/20 mb-8 reveal">
        <span class="w-2 h-2 rounded-full bg-lime animate-pulse"></span>
        <span class="text-sm font-label font-bold text-primary dark:text-blue-400 tracking-wide">Open for Projects</span>
      </div>
      <h1
        class="font-headline text-6xl md:text-8xl font-extrabold tracking-tight leading-none mb-8 text-on-surface dark:text-white reveal"
      >
        Bringing <span class="text-primary dark:text-blue-400">technical</span> precision
        to <span class="text-tertiary dark:text-purple-400">creative</span> souls.
      </h1>
      <p
        class="text-xl md:text-2xl text-on-surface-variant dark:text-slate-400 max-w-2xl mb-12 leading-relaxed reveal"
        style="transition-delay: 0.15s;"
      >
        Code&amp;Craft is where code meets craft. We tailor digital experiences with
        the meticulous care of a laboratory and the vision of a studio.
      </p>
      <div class="flex flex-wrap gap-4 reveal" style="transition-delay: 0.3s;">
        <a
          href="#contact"
          class="bg-gradient-to-r from-primary to-tertiary dark:from-blue-600 dark:to-purple-600 text-on-primary px-8 py-4 rounded-md font-bold tracking-tight hover:shadow-lg hover:shadow-primary/25 dark:hover:shadow-blue-500/20 transition-all active:scale-95 hover:-translate-y-0.5 inline-block"
        >
          Start Your Project
        </a>
        <a
          href="#services"
          class="border-2 border-outline-variant/30 dark:border-slate-700 px-8 py-4 rounded-md font-bold tracking-tight hover:bg-surface-container-low dark:hover:bg-slate-800 hover:border-primary/30 dark:hover:border-blue-500/30 transition-all inline-block"
        >
          View Services
        </a>
      </div>
    </div>

    <!-- Decorative Layering -->
    <div class="md:col-span-4 relative hidden md:block">
      <div
        class="absolute -top-20 -right-20 w-96 h-96 bg-gradient-to-br from-primary/20 via-pink/10 to-amber/10 dark:from-blue-500/10 dark:via-pink-500/5 dark:to-amber-500/5 rounded-full blur-[100px]"
      >
      </div>
      <div
        class="relative z-10 bg-surface-container-lowest dark:bg-slate-800 p-8 rounded-xl ambient-cloud transform rotate-3 scale-110 border border-outline-variant/10 dark:border-slate-700/30 animate-float"
      >
        <div
          class="rounded-lg mb-4 w-full h-48 bg-gradient-to-br from-primary/20 via-pink/15 to-amber/15 dark:from-blue-600/30 dark:via-pink-600/20 dark:to-amber-600/20 flex items-center justify-center"
        >
          <span
            class="material-symbols-outlined text-7xl text-primary/40 dark:text-blue-400/40"
            >science</span
          >
        </div>
        <div class="flex gap-2">
          <div class="h-2 w-24 bg-primary dark:bg-blue-500 rounded-full"></div>
          <div class="h-2 w-8 bg-pink dark:bg-pink-500 rounded-full"></div>
        </div>
        <div class="flex gap-2 mt-2">
          <div class="h-2 w-16 bg-tertiary dark:bg-purple-500 rounded-full"></div>
          <div class="h-2 w-10 bg-cyan dark:bg-cyan-500 rounded-full"></div>
        </div>
      </div>

      <!-- Small floating accent card -->
      <div class="absolute -bottom-8 -left-12 z-20 bg-surface-container-lowest dark:bg-slate-800 px-4 py-3 rounded-lg border border-outline-variant/10 dark:border-slate-700/30 shadow-lg animate-float-slow" style="animation-delay: 1s;">
        <div class="flex items-center gap-2">
          <div class="w-3 h-3 rounded-full bg-lime"></div>
          <span class="text-xs font-label font-bold text-on-surface-variant dark:text-slate-400">3 projects live</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Colorful divider at bottom -->
  <div class="absolute bottom-0 left-0 right-0 color-divider"></div>

  <!-- Large Watermark Type -->
  <div
    class="absolute bottom-0 left-0 -mb-20 opacity-[0.03] dark:opacity-[0.05] select-none pointer-events-none"
  >
    <span
      class="font-headline font-black text-[20rem] uppercase tracking-tighter"
      >CODE&amp;CRAFT</span
    >
  </div>
</section>

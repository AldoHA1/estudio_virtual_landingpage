---
---

<section class="py-24 px-8 bg-background dark:bg-slate-950 relative" id="contact">
  <!-- Background accents -->
  <div class="absolute top-20 left-10 w-[200px] h-[200px] bg-primary/5 dark:bg-blue-500/5 rounded-full blur-[80px] pointer-events-none"></div>
  <div class="absolute bottom-20 right-10 w-[200px] h-[200px] bg-pink/5 dark:bg-pink-500/5 rounded-full blur-[80px] pointer-events-none"></div>

  <div class="max-w-3xl mx-auto text-center mb-16 reveal">
    <h2 class="font-headline text-4xl md:text-5xl font-extrabold tracking-tight mb-4 dark:text-white">Start a <span class="text-primary dark:text-blue-400">Project</span></h2>
    <p class="text-on-surface-variant dark:text-slate-400 text-lg">Send us your brief, and let's engineer something remarkable together.</p>
    <div class="color-divider w-16 mx-auto mt-6"></div>
  </div>

  <div class="max-w-2xl mx-auto reveal">
    <form class="space-y-12" action="#" method="POST">
      <div class="relative group">
        <label for="name" class="block text-sm font-label font-bold text-on-surface-variant dark:text-slate-400 mb-2 px-1">Full Name</label>
        <input
          id="name"
          type="text"
          name="name"
          placeholder="John Doe"
          required
          class="w-full bg-background dark:bg-slate-900 border-0 border-b-2 border-outline-variant/30 dark:border-slate-700 focus:border-primary dark:focus:border-blue-500 focus:ring-0 transition-all px-4 py-3 text-lg dark:text-white dark:placeholder-slate-500"
        />
      </div>

      <div class="relative group">
        <label for="email" class="block text-sm font-label font-bold text-on-surface-variant dark:text-slate-400 mb-2 px-1">Email Address</label>
        <input
          id="email"
          type="email"
          name="email"
          placeholder="john@example.com"
          required
          class="w-full bg-background dark:bg-slate-900 border-0 border-b-2 border-outline-variant/30 dark:border-slate-700 focus:border-tertiary dark:focus:border-purple-500 focus:ring-0 transition-all px-4 py-3 text-lg dark:text-white dark:placeholder-slate-500"
        />
      </div>

      <div class="relative group">
        <label for="message" class="block text-sm font-label font-bold text-on-surface-variant dark:text-slate-400 mb-2 px-1">Project Message</label>
        <textarea
          id="message"
          name="message"
          placeholder="Describe your vision..."
          required
          rows="4"
          class="w-full bg-background dark:bg-slate-900 border-0 border-b-2 border-outline-variant/30 dark:border-slate-700 focus:border-pink dark:focus:border-pink-500 focus:ring-0 transition-all px-4 py-3 text-lg resize-none dark:text-white dark:placeholder-slate-500"
        ></textarea>
      </div>

      <div class="pt-6">
        <button
          type="submit"
          class="w-full bg-primary dark:bg-blue-600 text-on-primary py-5 rounded-md font-bold text-lg hover:shadow-2xl hover:shadow-primary/20 transition-all hover:-translate-y-1 active:scale-95 flex items-center justify-center gap-3 cursor-pointer"
        >
          <span class="material-symbols-outlined">send</span>
          Send Message
        </button>
      </div>
    </form>
  </div>
</section>

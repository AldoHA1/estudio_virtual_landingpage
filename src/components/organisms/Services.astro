---
---

<section class="py-24 px-8 bg-background dark:bg-slate-950 relative" id="services">
  <div class="max-w-7xl mx-auto">
    <div class="mb-16 reveal">
      <h2 class="font-headline text-4xl font-extrabold tracking-tighter mb-4 text-on-surface dark:text-white">Precision Services</h2>
      <div class="h-1.5 w-20 bg-gradient-to-r from-primary via-tertiary to-pink dark:from-blue-500 dark:via-purple-500 dark:to-pink-500 rounded-full"></div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <!-- Landing Pages -->
      <div class="reveal card-glow bg-surface-container-lowest dark:bg-slate-800 p-8 rounded-xl ambient-cloud border border-transparent hover:border-primary/20 dark:hover:border-blue-500/20 transition-all duration-300 group">
        <div class="w-12 h-12 rounded-md bg-gradient-to-br from-primary/10 to-cyan/10 dark:from-blue-500/10 dark:to-cyan-500/10 flex items-center justify-center text-primary dark:text-blue-400 mb-6 group-hover:scale-110 transition-transform">
          <span class="material-symbols-outlined">web</span>
        </div>
        <h3 class="font-headline text-xl font-bold mb-3 dark:text-white">Landing Pages</h3>
        <p class="text-on-surface-variant dark:text-slate-400 leading-relaxed">Conversion-optimized structures crafted for maximum impact and visual clarity.</p>
        <div class="mt-6 flex gap-1.5">
          <span class="w-8 h-1 rounded-full bg-primary dark:bg-blue-500"></span>
          <span class="w-4 h-1 rounded-full bg-cyan dark:bg-cyan-500"></span>
          <span class="w-2 h-1 rounded-full bg-primary/30 dark:bg-blue-500/30"></span>
        </div>
      </div>

      <!-- Web Development -->
      <div class="reveal card-glow bg-surface-container-lowest dark:bg-slate-800 p-8 rounded-xl ambient-cloud border border-transparent hover:border-secondary/20 dark:hover:border-emerald-500/20 transition-all duration-300 group" style="transition-delay: 0.1s;">
        <div class="w-12 h-12 rounded-md bg-gradient-to-br from-secondary/10 to-lime/10 dark:from-emerald-500/10 dark:to-lime-500/10 flex items-center justify-center text-secondary dark:text-emerald-400 mb-6 group-hover:scale-110 transition-transform">
          <span class="material-symbols-outlined">terminal</span>
        </div>
        <h3 class="font-headline text-xl font-bold mb-3 dark:text-white">Web Development</h3>
        <p class="text-on-surface-variant dark:text-slate-400 leading-relaxed">High-performance architecture built with clean code and laboratory-grade testing.</p>
        <div class="mt-6 flex gap-1.5">
          <span class="w-8 h-1 rounded-full bg-secondary dark:bg-emerald-500"></span>
          <span class="w-4 h-1 rounded-full bg-lime dark:bg-lime-500"></span>
          <span class="w-2 h-1 rounded-full bg-secondary/30 dark:bg-emerald-500/30"></span>
        </div>
      </div>

      <!-- Publicity Scripts (Tall Card) -->
      <div class="reveal card-glow bg-surface-container-lowest dark:bg-slate-800 p-8 rounded-xl ambient-cloud border border-transparent hover:border-tertiary/20 dark:hover:border-purple-500/20 transition-all duration-300 group md:row-span-2" style="transition-delay: 0.2s;">
        <div class="w-12 h-12 rounded-md bg-gradient-to-br from-tertiary/10 to-pink/10 dark:from-purple-500/10 dark:to-pink-500/10 flex items-center justify-center text-tertiary dark:text-purple-400 mb-6 group-hover:scale-110 transition-transform">
          <span class="material-symbols-outlined">script</span>
        </div>
        <h3 class="font-headline text-xl font-bold mb-3 dark:text-white">Publicity Scripts</h3>
        <p class="text-on-surface-variant dark:text-slate-400 leading-relaxed mb-6">Narrative-driven content engineered to trigger the right responses in your audience.</p>
        <div class="rounded-lg w-full h-48 bg-gradient-to-br from-tertiary/10 via-pink/10 to-amber/10 dark:from-purple-600/20 dark:via-pink-600/15 dark:to-amber-600/15 flex items-center justify-center">
          <span class="material-symbols-outlined text-6xl text-tertiary/30 dark:text-purple-400/30">edit_note</span>
        </div>
        <div class="mt-6 flex gap-1.5">
          <span class="w-8 h-1 rounded-full bg-tertiary dark:bg-purple-500"></span>
          <span class="w-4 h-1 rounded-full bg-pink dark:bg-pink-500"></span>
          <span class="w-2 h-1 rounded-full bg-amber dark:bg-amber-500"></span>
        </div>
      </div>

      <!-- Campaigns -->
      <div class="reveal card-glow bg-surface-container-lowest dark:bg-slate-800 p-8 rounded-xl ambient-cloud border border-transparent hover:border-coral/20 dark:hover:border-rose-500/20 transition-all duration-300 group" style="transition-delay: 0.3s;">
        <div class="w-12 h-12 rounded-md bg-gradient-to-br from-coral/10 to-amber/10 dark:from-rose-500/10 dark:to-amber-500/10 flex items-center justify-center text-coral dark:text-rose-400 mb-6 group-hover:scale-110 transition-transform">
          <span class="material-symbols-outlined">campaign</span>
        </div>
        <h3 class="font-headline text-xl font-bold mb-3 dark:text-white">Campaigns</h3>
        <p class="text-on-surface-variant dark:text-slate-400 leading-relaxed">Multi-channel growth strategies calculated to scale your digital presence.</p>
        <div class="mt-6 flex gap-1.5">
          <span class="w-8 h-1 rounded-full bg-coral dark:bg-rose-500"></span>
          <span class="w-4 h-1 rounded-full bg-amber dark:bg-amber-500"></span>
          <span class="w-2 h-1 rounded-full bg-coral/30 dark:bg-rose-500/30"></span>
        </div>
      </div>

      <!-- Product Development -->
      <div class="reveal card-glow bg-surface-container-lowest dark:bg-slate-800 p-8 rounded-xl ambient-cloud border border-transparent hover:border-cyan/20 dark:hover:border-cyan-500/20 transition-all duration-300 group" style="transition-delay: 0.4s;">
        <div class="w-12 h-12 rounded-md bg-gradient-to-br from-cyan/10 to-primary/10 dark:from-cyan-500/10 dark:to-blue-500/10 flex items-center justify-center text-cyan dark:text-cyan-400 mb-6 group-hover:scale-110 transition-transform">
          <span class="material-symbols-outlined">inventory_2</span>
        </div>
        <h3 class="font-headline text-xl font-bold mb-3 dark:text-white">Product Development</h3>
        <p class="text-on-surface-variant dark:text-slate-400 leading-relaxed">From MVP to full-scale digital ecosystem, we build products that endure.</p>
        <div class="mt-6 flex gap-1.5">
          <span class="w-8 h-1 rounded-full bg-cyan dark:bg-cyan-500"></span>
          <span class="w-4 h-1 rounded-full bg-primary dark:bg-blue-500"></span>
          <span class="w-2 h-1 rounded-full bg-cyan/30 dark:bg-cyan-500/30"></span>
        </div>
      </div>
    </div>
  </div>
</section>

---
---

<section class="py-24 px-8 bg-background dark:bg-slate-950 relative" id="services">
  <div class="max-w-7xl mx-auto">
    <div class="mb-16 reveal">
      <h2 class="font-headline text-4xl font-extrabold tracking-tighter mb-4 text-on-surface dark:text-white">Precision Services</h2>
      <div class="h-1.5 w-20 bg-gradient-to-r from-secondary via-primary to-tertiary dark:from-secondary-bright dark:via-primary-bright dark:to-tertiary-bright rounded-full"></div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <!-- Landing Pages -->
      <div class="reveal card-glow bg-surface-container-lowest dark:bg-slate-800 p-8 rounded-xl ambient-cloud border border-transparent hover:border-primary/25 dark:hover:border-primary-bright/20 transition-all duration-300 group">
        <div class="w-12 h-12 rounded-md bg-gradient-to-br from-primary/15 to-secondary/15 dark:from-primary-bright/15 dark:to-secondary-bright/15 flex items-center justify-center text-primary dark:text-primary-bright mb-6 group-hover:scale-110 transition-transform">
          <span class="material-symbols-outlined">web</span>
        </div>
        <h3 class="font-headline text-xl font-bold mb-3 dark:text-white">Landing Pages</h3>
        <p class="text-on-surface-variant dark:text-slate-400 leading-relaxed">Conversion-optimized structures crafted for maximum impact and visual clarity.</p>
        <div class="mt-6 flex gap-1.5">
          <span class="w-8 h-1 rounded-full bg-primary dark:bg-primary-bright"></span>
          <span class="w-4 h-1 rounded-full bg-secondary dark:bg-secondary-bright"></span>
          <span class="w-2 h-1 rounded-full bg-primary/30 dark:bg-primary-bright/30"></span>
        </div>
      </div>

      <!-- Web Development -->
      <div class="reveal card-glow bg-surface-container-lowest dark:bg-slate-800 p-8 rounded-xl ambient-cloud border border-transparent hover:border-secondary/25 dark:hover:border-secondary-bright/20 transition-all duration-300 group" style="transition-delay: 0.1s;">
        <div class="w-12 h-12 rounded-md bg-gradient-to-br from-secondary/15 to-tertiary/15 dark:from-secondary-bright/15 dark:to-tertiary-bright/15 flex items-center justify-center text-secondary dark:text-secondary-bright mb-6 group-hover:scale-110 transition-transform">
          <span class="material-symbols-outlined">terminal</span>
        </div>
        <h3 class="font-headline text-xl font-bold mb-3 dark:text-white">Web Development</h3>
        <p class="text-on-surface-variant dark:text-slate-400 leading-relaxed">High-performance architecture built with clean code and laboratory-grade testing.</p>
        <div class="mt-6 flex gap-1.5">
          <span class="w-8 h-1 rounded-full bg-secondary dark:bg-secondary-bright"></span>
          <span class="w-4 h-1 rounded-full bg-tertiary dark:bg-tertiary-bright"></span>
          <span class="w-2 h-1 rounded-full bg-secondary/30 dark:bg-secondary-bright/30"></span>
        </div>
      </div>

      <!-- Publicity Scripts (Tall Card) -->
      <div class="reveal card-glow bg-surface-container-lowest dark:bg-slate-800 p-8 rounded-xl ambient-cloud border border-transparent hover:border-tertiary/30 dark:hover:border-tertiary-bright/25 transition-all duration-300 group md:row-span-2" style="transition-delay: 0.2s;">
        <div class="w-12 h-12 rounded-md bg-gradient-to-br from-tertiary/15 to-neutral/40 dark:from-tertiary-bright/20 dark:to-neutral/15 flex items-center justify-center text-tertiary dark:text-tertiary-bright mb-6 group-hover:scale-110 transition-transform">
          <span class="material-symbols-outlined">script</span>
        </div>
        <h3 class="font-headline text-xl font-bold mb-3 dark:text-white">Publicity Scripts</h3>
        <p class="text-on-surface-variant dark:text-slate-400 leading-relaxed mb-6">Narrative-driven content engineered to trigger the right responses in your audience.</p>
        <div class="rounded-lg w-full h-48 bg-gradient-to-br from-tertiary/20 via-primary/10 to-neutral/40 dark:from-tertiary-bright/20 dark:via-primary-bright/15 dark:to-neutral/15 flex items-center justify-center">
          <span class="material-symbols-outlined text-6xl text-tertiary/40 dark:text-tertiary-bright/40">edit_note</span>
        </div>
        <div class="mt-6 flex gap-1.5">
          <span class="w-8 h-1 rounded-full bg-tertiary dark:bg-tertiary-bright"></span>
          <span class="w-4 h-1 rounded-full bg-primary dark:bg-primary-bright"></span>
          <span class="w-2 h-1 rounded-full bg-neutral dark:bg-neutral-bright"></span>
        </div>
      </div>

      <!-- Campaigns -->
      <div class="reveal card-glow bg-surface-container-lowest dark:bg-slate-800 p-8 rounded-xl ambient-cloud border border-transparent hover:border-secondary/25 dark:hover:border-secondary-bright/20 transition-all duration-300 group" style="transition-delay: 0.3s;">
        <div class="w-12 h-12 rounded-md bg-gradient-to-br from-secondary/15 to-primary/15 dark:from-secondary-bright/15 dark:to-primary-bright/15 flex items-center justify-center text-secondary dark:text-secondary-bright mb-6 group-hover:scale-110 transition-transform">
          <span class="material-symbols-outlined">campaign</span>
        </div>
        <h3 class="font-headline text-xl font-bold mb-3 dark:text-white">Campaigns</h3>
        <p class="text-on-surface-variant dark:text-slate-400 leading-relaxed">Multi-channel growth strategies calculated to scale your digital presence.</p>
        <div class="mt-6 flex gap-1.5">
          <span class="w-8 h-1 rounded-full bg-secondary dark:bg-secondary-bright"></span>
          <span class="w-4 h-1 rounded-full bg-primary dark:bg-primary-bright"></span>
          <span class="w-2 h-1 rounded-full bg-secondary/30 dark:bg-secondary-bright/30"></span>
        </div>
      </div>

      <!-- Product Development -->
      <div class="reveal card-glow bg-surface-container-lowest dark:bg-slate-800 p-8 rounded-xl ambient-cloud border border-transparent hover:border-neutral/50 dark:hover:border-neutral-bright/30 transition-all duration-300 group" style="transition-delay: 0.4s;">
        <div class="w-12 h-12 rounded-md bg-gradient-to-br from-neutral/40 to-primary/15 dark:from-neutral/20 dark:to-primary-bright/15 flex items-center justify-center text-tertiary dark:text-neutral mb-6 group-hover:scale-110 transition-transform">
          <span class="material-symbols-outlined">inventory_2</span>
        </div>
        <h3 class="font-headline text-xl font-bold mb-3 dark:text-white">Product Development</h3>
        <p class="text-on-surface-variant dark:text-slate-400 leading-relaxed">From MVP to full-scale digital ecosystem, we build products that endure.</p>
        <div class="mt-6 flex gap-1.5">
          <span class="w-8 h-1 rounded-full bg-neutral dark:bg-neutral-bright"></span>
          <span class="w-4 h-1 rounded-full bg-primary dark:bg-primary-bright"></span>
          <span class="w-2 h-1 rounded-full bg-neutral/50 dark:bg-neutral-bright/40"></span>
        </div>
      </div>
    </div>
  </div>
</section>

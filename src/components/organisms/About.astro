---

---

<section class="py-24 px-8 bg-background dark:bg-slate-950 relative" id="about">
  <!-- Subtle background accent -->
  <div
    class="absolute top-0 right-0 w-[300px] h-[300px] bg-secondary/5 dark:bg-secondary-bright/8 rounded-full blur-[100px] pointer-events-none"
  >
  </div>
  <div
    class="absolute bottom-0 left-0 w-[250px] h-[250px] bg-tertiary/5 dark:bg-tertiary-bright/8 rounded-full blur-[100px] pointer-events-none"
  >
  </div>

  <div
    class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-10 gap-16 items-center"
  >
    <div class="md:col-span-4 relative reveal-left">
      <div
        class="aspect-[4/5] bg-surface-variant dark:bg-slate-800 rounded-xl overflow-hidden shadow-2xl flex items-center justify-center"
      >
        <div
          class="w-full h-full bg-gradient-to-br from-primary/15 via-secondary/10 to-neutral/25 dark:from-primary-bright/20 dark:via-secondary-bright/15 dark:to-neutral/15 flex items-center justify-center"
        >
          <span
            class="material-symbols-outlined text-9xl text-primary/25 dark:text-primary-bright/25"
            style="font-size: 8rem;">groups</span
          >
        </div>
      </div>
      <!-- Floating accent dots -->
      <div class="absolute -top-4 -right-4 flex gap-2">
        <div
          class="w-4 h-4 rounded-full bg-primary dark:bg-primary-bright animate-float"
          style="animation-delay: 0s;"
        >
        </div>
        <div
          class="w-3 h-3 rounded-full bg-secondary dark:bg-secondary-bright animate-float"
          style="animation-delay: 0.5s;"
        >
        </div>
        <div
          class="w-2 h-2 rounded-full bg-tertiary dark:bg-tertiary-bright animate-float"
          style="animation-delay: 1s;"
        >
        </div>
      </div>
    </div>

    <div class="md:col-span-6 reveal-right">
      <h4
        class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-tertiary dark:from-primary-bright dark:to-tertiary-bright font-bold tracking-[0.2em] uppercase text-sm mb-6 font-label gradient-text"
      >
        The Philosophy
      </h4>
      <h2
        class="font-headline text-4xl md:text-5xl font-extrabold tracking-tight mb-8 leading-tight dark:text-white"
      >
        A studio where logic <span
          class="italic text-secondary dark:text-secondary-bright">meets</span
        > creativity.
      </h2>
      <div
        class="space-y-6 text-lg text-on-surface-variant dark:text-slate-400 leading-relaxed"
      >
        <p>
          At Code&amp;Craft, we don't just design; we hypothesize, test, and refine.
          Our laboratory-like approach ensures that every pixel has a purpose
          and every line of code serves a function.
        </p>
        <p>
          We believe in "Digital Tailoring" — the idea that software should fit
          your business like a bespoke suit. No off-the-shelf templates, no
          generic solutions. Only precision-engineered growth.
        </p>
      </div>
      <!-- Colorful stats row -->
      <div class="flex flex-wrap gap-8 mt-10">
        <div class="reveal" style="transition-delay: 0.2s;">
          <div
            class="text-3xl font-headline font-extrabold text-primary dark:text-primary-bright"
          >
            50+
          </div>
          <div
            class="text-sm text-on-surface-variant dark:text-slate-500 font-label"
          >
            Projects
          </div>
        </div>
        <div class="reveal" style="transition-delay: 0.3s;">
          <div
            class="text-3xl font-headline font-extrabold text-secondary dark:text-secondary-bright"
          >
            98%
          </div>
          <div
            class="text-sm text-on-surface-variant dark:text-slate-500 font-label"
          >
            Satisfaction
          </div>
        </div>
        <div class="reveal" style="transition-delay: 0.4s;">
          <div
            class="text-3xl font-headline font-extrabold text-tertiary dark:text-tertiary-bright"
          >
            3y
          </div>
          <div
            class="text-sm text-on-surface-variant dark:text-slate-500 font-label"
          >
            Experience
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Meet the Team -->
  <div class="max-w-7xl mx-auto mt-32">
    <div class="text-center mb-16 reveal">
      <h4
        class="text-transparent bg-clip-text bg-gradient-to-r from-secondary to-tertiary dark:from-secondary-bright dark:to-tertiary-bright font-bold tracking-[0.2em] uppercase text-sm mb-4 font-label gradient-text"
      >
        The People
      </h4>
      <h2
        class="font-headline text-4xl md:text-5xl font-extrabold tracking-tight mb-4 dark:text-white"
      >
        Meet the Minds Behind Code&amp;Craft
      </h2>
      <p
        class="text-on-surface-variant dark:text-slate-400 text-lg max-w-2xl mx-auto"
      >
        A small, focused team that blends engineering rigor with creative
        intuition.
      </p>
      <div class="color-divider w-16 mx-auto mt-6"></div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-8 max-w-3xl mx-auto">
      <!-- Member 1 -->
      <div
        class="reveal card-glow bg-surface-container-lowest dark:bg-slate-800 rounded-xl p-8 text-center border border-transparent hover:border-primary/20 dark:hover:border-primary-bright/20 ambient-cloud"
        style="transition-delay: 0.1s;"
      >
        <img
          src={`${import.meta.env.BASE_URL}team/aldo-herrera.jpg`}
          alt="Aldo Herrera"
          class="w-24 h-24 mx-auto mb-6 rounded-full object-cover"
        />
        <h3 class="font-headline text-lg font-bold dark:text-white mb-1">
          Aldo Herrera
        </h3>
        <p
          class="text-sm font-label text-primary dark:text-primary-bright font-bold mb-4"
        >
          Founder & Lead Developer
        </p>
        <p
          class="text-on-surface-variant dark:text-slate-400 text-sm leading-relaxed"
        >
          Full-stack architect with a passion for clean code and scalable
          systems.
        </p>
        <div class="flex justify-center gap-1.5 mt-5">
          <span class="w-6 h-1 rounded-full bg-primary dark:bg-primary-bright"></span>
          <span class="w-3 h-1 rounded-full bg-tertiary dark:bg-tertiary-bright"></span>
        </div>
      </div>

      <!-- Member 2 -->
      <div
        class="reveal card-glow bg-surface-container-lowest dark:bg-slate-800 rounded-xl p-8 text-center border border-transparent hover:border-secondary/20 dark:hover:border-secondary-bright/20 ambient-cloud"
        style="transition-delay: 0.2s;"
      >
        <img
          src={`${import.meta.env.BASE_URL}team/pamela-orozco.jpg`}
          alt="Pamela Orozco"
          class="w-24 h-24 mx-auto mb-6 rounded-full object-cover"
        />
        <h3 class="font-headline text-lg font-bold dark:text-white mb-1">
          Pamela Orozco
        </h3>
        <p
          class="text-sm font-label text-secondary dark:text-secondary-bright font-bold mb-4"
        >
          Founder & Creative Director
        </p>
        <p
          class="text-on-surface-variant dark:text-slate-400 text-sm leading-relaxed"
        >
          Transforms brand narratives into visual experiences that resonate and
          convert.
        </p>
        <div class="flex justify-center gap-1.5 mt-5">
          <span class="w-6 h-1 rounded-full bg-secondary dark:bg-secondary-bright"
          ></span>
          <span class="w-3 h-1 rounded-full bg-neutral dark:bg-neutral-bright"></span>
        </div>
      </div>
    </div>
  </div>
</section>

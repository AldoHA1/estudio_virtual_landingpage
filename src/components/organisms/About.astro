---

---

<section class="py-24 px-8 bg-background dark:bg-slate-950 relative" id="about">
  <!-- Subtle background accent -->
  <div
    class="absolute top-0 right-0 w-[300px] h-[300px] bg-secondary/5 dark:bg-secondary-bright/8 rounded-full blur-[100px] pointer-events-none"
  >
  </div>
  <div
    class="absolute bottom-0 left-0 w-[250px] h-[250px] bg-tertiary/5 dark:bg-tertiary-bright/8 rounded-full blur-[100px] pointer-events-none"
  >
  </div>

  <div
    class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-10 gap-16 items-center"
  >
    <div class="md:col-span-4 relative reveal-left">
      <div
        class="aspect-[4/5] bg-surface-variant dark:bg-slate-800 rounded-xl overflow-hidden shadow-2xl flex items-center justify-center"
      >
        <div
          class="w-full h-full bg-gradient-to-br from-primary/15 via-secondary/10 to-neutral/25 dark:from-primary-bright/20 dark:via-secondary-bright/15 dark:to-neutral/15 flex items-center justify-center"
        >
          <span
            class="material-symbols-outlined text-9xl text-primary/25 dark:text-primary-bright/25"
            style="font-size: 8rem;">groups</span
          >
        </div>
      </div>
      <!-- Floating accent dots -->
      <div class="absolute -top-4 -right-4 flex gap-2">
        <div
          class="w-4 h-4 rounded-full bg-primary dark:bg-primary-bright animate-float"
          style="animation-delay: 0s;"
        >
        </div>
        <div
          class="w-3 h-3 rounded-full bg-secondary dark:bg-secondary-bright animate-float"
          style="animation-delay: 0.5s;"
        >
        </div>
        <div
          class="w-2 h-2 rounded-full bg-tertiary dark:bg-tertiary-bright animate-float"
          style="animation-delay: 1s;"
        >
        </div>
      </div>
    </div>

    <div class="md:col-span-6 reveal-right">
      <h4
        class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-tertiary dark:from-primary-bright dark:to-tertiary-bright font-bold tracking-[0.2em] uppercase text-sm mb-6 font-label gradient-text"
      >
        Who We Are
      </h4>
      <h2
        class="font-headline text-4xl md:text-5xl font-extrabold tracking-tight mb-8 leading-tight dark:text-white"
      >
        Where storytelling <span
          class="italic text-secondary dark:text-secondary-bright">meets</span
        > unbreakable engineering.
      </h2>
      <div
        class="space-y-6 text-lg text-on-surface-variant dark:text-slate-400 leading-relaxed"
      >
        <p>
          A boutique web creation studio led by experts in strategic narrative and technical development. We unite top-tier creative talent with real Full-stack engineering — no industrial factory, just a high-precision Studio.
        </p>
        <p>
          Most agencies are noise: ad shops bring creativity they can't build, and big dev houses have the muscle but lack the soul. We're the exact point where storytelling meets a rock-solid technical architecture. If it doesn't tell a story, it's just noise.
        </p>
      </div>
      <!-- Colorful stats row -->
      <div class="flex flex-wrap gap-8 mt-10">
        <div class="reveal" style="transition-delay: 0.2s;">
          <div
            class="text-3xl font-headline font-extrabold text-primary dark:text-primary-bright"
          >
            14y
          </div>
          <div
            class="text-sm text-on-surface-variant dark:text-slate-500 font-label"
          >
            Combined Experience
          </div>
        </div>
        <div class="reveal" style="transition-delay: 0.3s;">
          <div
            class="text-3xl font-headline font-extrabold text-secondary dark:text-secondary-bright"
          >
            1
          </div>
          <div
            class="text-sm text-on-surface-variant dark:text-slate-500 font-label"
          >
            Project at a Time
          </div>
        </div>
        <div class="reveal" style="transition-delay: 0.4s;">
          <div
            class="text-3xl font-headline font-extrabold text-tertiary dark:text-tertiary-bright"
          >
            0
          </div>
          <div
            class="text-sm text-on-surface-variant dark:text-slate-500 font-label"
          >
            Middlemen
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Why Us pillars -->
  <div class="max-w-7xl mx-auto mt-32">
    <div class="text-center mb-16 reveal">
      <h4
        class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-secondary dark:from-primary-bright dark:to-secondary-bright font-bold tracking-[0.2em] uppercase text-sm mb-4 font-label gradient-text"
      >
        Why Us
      </h4>
      <h2
        class="font-headline text-4xl md:text-5xl font-extrabold tracking-tight mb-4 dark:text-white"
      >
        14 years of combined experience, <span class="italic text-tertiary dark:text-tertiary-bright">poured into one project</span>: yours.
      </h2>
      <p class="text-on-surface-variant dark:text-slate-400 text-lg max-w-2xl mx-auto">
        Pure code designed to grow and endure.
      </p>
      <div class="color-divider w-16 mx-auto mt-6"></div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <div class="reveal card-glow bg-surface-container-lowest dark:bg-slate-800 p-8 rounded-xl ambient-cloud border border-transparent hover:border-primary/20 dark:hover:border-primary-bright/20 transition-all duration-300 group">
        <div class="w-12 h-12 rounded-md bg-gradient-to-br from-primary/10 to-secondary/10 dark:from-primary-bright/15 dark:to-secondary-bright/15 flex items-center justify-center text-primary dark:text-primary-bright mb-6 group-hover:scale-110 transition-transform">
          <span class="material-symbols-outlined">diamond</span>
        </div>
        <h3 class="font-headline text-xl font-bold mb-3 dark:text-white">Boutique</h3>
        <p class="text-on-surface-variant dark:text-slate-400 leading-relaxed">
          No mass-managed accounts. One project at a time, so every line of code and every word carries real business purpose.
        </p>
        <div class="mt-6 flex gap-1.5">
          <span class="w-8 h-1 rounded-full bg-primary dark:bg-primary-bright"></span>
          <span class="w-4 h-1 rounded-full bg-secondary dark:bg-secondary-bright"></span>
          <span class="w-2 h-1 rounded-full bg-primary/30 dark:bg-primary-bright/30"></span>
        </div>
      </div>

      <div class="reveal card-glow bg-surface-container-lowest dark:bg-slate-800 p-8 rounded-xl ambient-cloud border border-transparent hover:border-secondary/20 dark:hover:border-secondary-bright/20 transition-all duration-300 group" style="transition-delay: 0.1s;">
        <div class="w-12 h-12 rounded-md bg-gradient-to-br from-secondary/10 to-tertiary/10 dark:from-secondary-bright/15 dark:to-tertiary-bright/15 flex items-center justify-center text-secondary dark:text-secondary-bright mb-6 group-hover:scale-110 transition-transform">
          <span class="material-symbols-outlined">handshake</span>
        </div>
        <h3 class="font-headline text-xl font-bold mb-3 dark:text-white">Experts in Charge</h3>
        <p class="text-on-surface-variant dark:text-slate-400 leading-relaxed">
          No middlemen. Work directly with the specialists leading the creative strategy and the technical execution of your platform.
        </p>
        <div class="mt-6 flex gap-1.5">
          <span class="w-8 h-1 rounded-full bg-secondary dark:bg-secondary-bright"></span>
          <span class="w-4 h-1 rounded-full bg-tertiary dark:bg-tertiary-bright"></span>
          <span class="w-2 h-1 rounded-full bg-secondary/30 dark:bg-secondary-bright/30"></span>
        </div>
      </div>

      <div class="reveal card-glow bg-surface-container-lowest dark:bg-slate-800 p-8 rounded-xl ambient-cloud border border-transparent hover:border-tertiary/20 dark:hover:border-tertiary-bright/20 transition-all duration-300 group" style="transition-delay: 0.2s;">
        <div class="w-12 h-12 rounded-md bg-gradient-to-br from-tertiary/10 to-neutral/20 dark:from-tertiary-bright/15 dark:to-neutral/15 flex items-center justify-center text-tertiary dark:text-tertiary-bright mb-6 group-hover:scale-110 transition-transform">
          <span class="material-symbols-outlined">favorite</span>
        </div>
        <h3 class="font-headline text-xl font-bold mb-3 dark:text-white">Technical Muscle, Creative Soul</h3>
        <p class="text-on-surface-variant dark:text-slate-400 leading-relaxed">
          We build digital products that don't just work flawlessly — they live, breathe, and resonate with whoever visits them.
        </p>
        <div class="mt-6 flex gap-1.5">
          <span class="w-8 h-1 rounded-full bg-tertiary dark:bg-tertiary-bright"></span>
          <span class="w-4 h-1 rounded-full bg-neutral dark:bg-neutral-bright"></span>
          <span class="w-2 h-1 rounded-full bg-tertiary/30 dark:bg-tertiary-bright/30"></span>
        </div>
      </div>
    </div>
  </div>

  <!-- Meet the Team -->
  <div class="max-w-7xl mx-auto mt-32">
    <div class="text-center mb-16 reveal">
      <h4
        class="text-transparent bg-clip-text bg-gradient-to-r from-secondary to-tertiary dark:from-secondary-bright dark:to-tertiary-bright font-bold tracking-[0.2em] uppercase text-sm mb-4 font-label gradient-text"
      >
        The People
      </h4>
      <h2
        class="font-headline text-4xl md:text-5xl font-extrabold tracking-tight mb-4 dark:text-white"
      >
        Meet the Minds Behind Code&amp;Craft
      </h2>
      <p
        class="text-on-surface-variant dark:text-slate-400 text-lg max-w-2xl mx-auto"
      >
        A small, focused team where strategic narrative and Full-stack engineering speak the same language.
      </p>
      <div class="color-divider w-16 mx-auto mt-6"></div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-8 max-w-3xl mx-auto">
      <!-- Member 1 -->
      <div
        class="reveal card-glow bg-surface-container-lowest dark:bg-slate-800 rounded-xl p-8 text-center border border-transparent hover:border-primary/20 dark:hover:border-primary-bright/20 ambient-cloud"
        style="transition-delay: 0.1s;"
      >
        <img
          src={`${import.meta.env.BASE_URL}team/aldo-herrera.jpg`}
          alt="Aldo Herrera"
          class="w-24 h-24 mx-auto mb-6 rounded-full object-cover"
        />
        <h3 class="font-headline text-lg font-bold dark:text-white mb-1">
          Aldo Herrera
        </h3>
        <p
          class="text-sm font-label text-primary dark:text-primary-bright font-bold mb-4"
        >
          Founder & Lead Developer
        </p>
        <p
          class="text-on-surface-variant dark:text-slate-400 text-sm leading-relaxed"
        >
          Full-stack architect with a passion for clean code and scalable
          systems.
        </p>
        <div class="flex justify-center gap-1.5 mt-5">
          <span class="w-6 h-1 rounded-full bg-primary dark:bg-primary-bright"></span>
          <span class="w-3 h-1 rounded-full bg-tertiary dark:bg-tertiary-bright"></span>
        </div>
      </div>

      <!-- Member 2 -->
      <div
        class="reveal card-glow bg-surface-container-lowest dark:bg-slate-800 rounded-xl p-8 text-center border border-transparent hover:border-secondary/20 dark:hover:border-secondary-bright/20 ambient-cloud"
        style="transition-delay: 0.2s;"
      >
        <img
          src={`${import.meta.env.BASE_URL}team/pamela-orozco.jpg`}
          alt="Pamela Orozco"
          class="w-24 h-24 mx-auto mb-6 rounded-full object-cover"
        />
        <h3 class="font-headline text-lg font-bold dark:text-white mb-1">
          Pamela Orozco
        </h3>
        <p
          class="text-sm font-label text-secondary dark:text-secondary-bright font-bold mb-4"
        >
          Founder & Creative Director
        </p>
        <p
          class="text-on-surface-variant dark:text-slate-400 text-sm leading-relaxed"
        >
          Transforms brand narratives into visual experiences that resonate and
          convert.
        </p>
        <div class="flex justify-center gap-1.5 mt-5">
          <span class="w-6 h-1 rounded-full bg-secondary dark:bg-secondary-bright"
          ></span>
          <span class="w-3 h-1 rounded-full bg-neutral dark:bg-neutral-bright"></span>
        </div>
      </div>
    </div>
  </div>
</section>
